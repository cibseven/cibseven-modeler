{
  "name": "cibseven-modeler",
  "version": "1.0.0-dev.4",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/cibseven-modeler.umd.js",
  "module": "./dist/cibseven-modeler.es.js",
  "style": "dist/cibseven-modeler.css",
  "files": [
    "dist/cibseven-modeler.css",
    "dist/cibseven-modeler.es.js",
    "dist/cibseven-modeler.umd.js"
  ],
  "exports": {
    ".": {
      "import": "./dist/cibseven-modeler.es.js",
      "require": "./dist/cibseven-modeler.umd.js"
    },
    "./dist/cibseven-modeler.css": "./dist/cibseven-modeler.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "cross-env BUILD_MODE=library vite build",
    "build:watch": "cross-env BUILD_MODE=library vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --coverage --reporter=default --reporter=junit --outputFile=target/vitest-reports/TEST-front-end.xml",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "install-clean": "npm ci",
    "install-exact": "npm install --save-exact",
    "check-exact": "node -e \"const pkg=require('./package.json'); const deps=[...Object.entries(pkg.dependencies||{}), ...Object.entries(pkg.devDependencies||{})]; const ranges=deps.filter(([n,v])=>v.match(/[~^*>=<]/)); if(ranges.length){console.error('Version ranges found:',ranges.map(([n])=>n)); process.exit(1);} console.log('All versions are exact');\""
  },
  "dependencies": {
    "@bpmn-io/dmn-migrate": "0.6.0",
    "@bpmn-io/element-template-chooser": "2.0.0",
    "bpmn-js-bpmnlint": "0.23.0",
    "bpmn-js-color-picker": "0.7.2",
    "bpmn-js-element-templates": "2.4.0",
    "bpmn-js-properties-panel": "5.30.0",
    "camunda-bpmn-js-behaviors": "1.9.0",
    "camunda-bpmn-moddle": "7.0.1",
    "camunda-dmn-moddle": "1.3.0",
    "diagram-js": "15.3.0",
    "diagram-js-minimap": "5.2.0",
    "dmn-js-properties-panel": "3.7.0",
    "min-dash": "4.2.2",
    "monaco-editor": "0.53.0"
  },
  "devDependencies": {
    "@bpmn-io/form-js": "1.15.2",
    "@cib/common-frontend": "1.0.3-dev.13",
    "@eslint/js": "9.39.2",
    "@vitejs/plugin-vue": "5.2.4",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vitest/eslint-plugin": "1.1.44",
    "@vue/compiler-dom": "3.5.16",
    "@vue/server-renderer": "3.5.16",
    "@vue/test-utils": "2.4.6",
    "axios": "1.15.2",
    "bootstrap": "5.3.8",
    "bpmn-js": "18.3.2",
    "bpmnlint-loader": "0.1.6",
    "cross-env": "7.0.3",
    "dmn-js": "17.2.0",
    "eslint": "9.39.2",
    "eslint-plugin-vue": "10.5.0",
    "eslint-plugin-vuejs-accessibility": "2.4.1",
    "jsdom": "26.1.0",
    "less": "4.2.1",
    "moment": "2.30.1",
    "vite": "6.4.2",
    "vitest": "3.2.4",
    "vue": "3.5.16",
    "vue-eslint-parser": "10.2.0",
    "vue-i18n": "11.1.10",
    "vue-router": "4.5.1",
    "vuex": "4.1.0"
  },
  "peerDependencies": {
    "@bpmn-io/form-js": "^1.15.2",
    "@cib/common-frontend": "^1.0.3-dev.13",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "bpmn-js": "^18.3.2",
    "dmn-js": "^17.2.0",
    "moment": "^2.30.1",
    "vue": "^3.5.16",
    "vue-i18n": "^11.1.10",
    "vue-router": "^4.5.1",
    "vuex": "^4.1.0"
  },
  "overrides": {
    "eslint-plugin-vue": "10.5.0",
    "vue-eslint-parser": "10.2.0"
  },
  "publishConfig": {
    "registry": "https://artifacts.cibseven.org/repository/npm-hosted/"
  }
}
